+            {"payload": {"players_added_ids": ["P2", "P3"]}},
+            {"payload": {}},
+        ]
+        ids = _collect_player_ids_from_events(events)
+        assert "P1" in ids
+        assert "P2" in ids
+        assert "P3" in ids
+
+    def test_collect_franchise_ids(self):
