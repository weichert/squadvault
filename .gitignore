# SquadVault .gitignore
# Clean version — historical patch management rules removed.

# Python
__pycache__/
*.pyc
*.pyo
*.pyd
.venv/
env/
venv/
*.egg-info/

# Hypothesis test cache
.hypothesis/

# Environment & secrets
.env
.env.*

# Local databases
*.sqlite
*.sqlite*
*.db
*.bak

# OS junk
.DS_Store

# Generated artifacts (default: ignored)
artifacts/**
!artifacts/CREATIVE_SURFACE_FINGERPRINT_v1.json

# Generated outputs (season-html, exports)
outputs/

# Local audit / CI logs
.local_audit/
.local_ci_logs/
path1_logs/
*.log
_extracted_txt/
_sprint1_context_*.txt
faab_splash_sheet*

# Save files
*.save

# Tests directory: tracked (override default ignore)
!Tests/
!Tests/**/*.py

# Legacy test files (untracked intentionally)
Tests/test_auction_draft_envelopes.py
Tests/test_store_append_only.py
Tests/test_transaction_envelopes.py
Tests/test_waiver_bid_envelopes.py

# Fixtures: tracked
!fixtures/
!fixtures/ci_squadvault.sqlite

# Patch scripts in scripts/ (not archive): ignored by default
scripts/_patch_*.py
scripts/_diag_*.py

# Archive is always tracked
!scripts/_archive/**

# Local CI helpers
scripts/ci_watch_and_diagnose_run_v*.sh

# Delivery scripts in repo root only (should be archived after use)
/apply_*.py
