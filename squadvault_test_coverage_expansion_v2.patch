+        v1, _ = create_recap_artifact_draft_idempotent(
+            db, LEAGUE, SEASON, WEEK, FP, None, None, "v1",
+        )
+        approve_recap_artifact(db, LEAGUE, SEASON, WEEK, v1, "founder")
